# ───────────────────────────────────────────────────────────
# 求职雷达 Agent API — 环境变量配置模板
# 复制为 .env 后填入你的实际密钥
# 本地模型 (Ollama/vLLM/LM Studio) 兼容：BASE_URL 填本地地址，API_KEY 留空
# ───────────────────────────────────────────────────────────

# ── Chat 模型 — 对话最终回复生成 ──
CHAT_BASE_URL=https://api.openai.com/v1
CHAT_API_KEY=your-api-key-here
CHAT_MODEL=gpt-4o

# ── Core 模型 — 核心业务分析（匹配分析、面试题生成） ──
# 留空则复用 CHAT_*
CORE_BASE_URL=
CORE_API_KEY=
CORE_MODEL=

# ── Planner 模型 — 规划与推理（意图识别、query改写、plan生成） ──
# 可用中等能力模型降低成本，留空则复用 CHAT_*
PLANNER_BASE_URL=
PLANNER_API_KEY=
PLANNER_MODEL=

# ── Memory 模型 — 记忆管理（压缩、长期记忆提取） ──
# 可用最便宜模型，留空则复用 CHAT_*
MEMORY_BASE_URL=
MEMORY_API_KEY=
MEMORY_MODEL=

# ── Vision 模型 — 多模态（图片 OCR、JD 截图解析） ──
VISION_BASE_URL=https://api.openai.com/v1
VISION_API_KEY=
VISION_MODEL=gpt-4o

# ── Judge 模型 — 评测用 LLM-as-judge（评估回复质量） ──
# 可用 cheapest 小模型，留空则复用 MEMORY_* → CHAT_*
JUDGE_BASE_URL=
JUDGE_API_KEY=
JUDGE_MODEL=

# ── Embedding 模型 — 向量库向量化 ──
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── 本地模型示例（Ollama） ──
# CHAT_BASE_URL=http://localhost:11434/v1
# CHAT_API_KEY=
# CHAT_MODEL=qwen2.5:14b
