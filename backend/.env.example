# ═══════════════════════════════════════════════════════════
# 求职雷达 Agent — 模型配置（国内模型版 · 双池映射）
# ═══════════════════════════════════════════════════════════
# 配置思路：
#   1. 先定义"大模型池"和"小模型池"（各一套 URL/KEY/MODEL）
#   2. 再通过 *_LAYER 决定各系统层级使用哪个池
#   3. 某层如需独立配置，设为 "custom" 并填写该层独立参数
#
# 国内模型推荐：
#   大模型（强推理）：qwen-plus / deepseek-v3 / moonshot-v1-32k
#   小模型（轻量快）：qwen-turbo / glm-4-flash / 本地 qwen2.5:7b
#   多模态 Vision：qwen-vl-plus
#   Embedding：text-embedding-v4（DashScope）
#
# 【本地模型兼容】Ollama / vLLM：
#   BASE_URL = http://localhost:11434/v1
#   API_KEY 留空
#   MODEL   = qwen2.5:14b / deepseek-r1 等
# ═══════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────
# 一、大模型池（强推理任务）
# ───────────────────────────────────────────────────────────
# 承担：最终对话回复、简历匹配分析、面试题生成、任务规划、意图兜底仲裁
# 推荐：qwen-plus（通义千问增强版，32K上下文，推理强）
#       或 deepseek-v3（深度求索，性价比极高）
#       或 moonshot-v1-32k（Kimi，长文本优秀）
LARGE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LARGE_API_KEY=sk-your-key-here
LARGE_MODEL=qwen-plus

# ───────────────────────────────────────────────────────────
# 二、小模型池（轻量快速任务）
# ───────────────────────────────────────────────────────────
# 承担：query改写、意图识别L2审核、记忆压缩、评测打分
# 推荐：qwen-turbo（通义千问极速版，极便宜）
#       或 glm-4-flash（智谱，免费额度多）
#       或本地 qwen2.5:7b（零成本，需 Ollama）
SMALL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SMALL_API_KEY=sk-your-key-here
SMALL_MODEL=qwen-turbo

# ───────────────────────────────────────────────────────────
# 三、系统层级 → 模型池映射
# ───────────────────────────────────────────────────────────
# 值填 large | small | custom
#   large  → 复用【大模型池】（上方 LARGE_*）
#   small  → 复用【小模型池】（上方 SMALL_*）
#   custom → 使用下方【各层独立配置】（*_BASE_URL / *_API_KEY / *_MODEL）
#
# 默认推荐映射：
CHAT_LAYER=large        # 最终回复生成、意图识别第一层（L1）
CORE_LAYER=large        # 匹配分析、面试题生成、简历解析、QA合成
PLANNER_LAYER=large     # 任务规划、检索决策、意图识别兜底仲裁
REWRITE_LAYER=small     # query改写、指代消解、口语降噪
MEMORY_LAYER=small      # 记忆压缩、话题切换、意图识别第二层（L2）
JUDGE_LAYER=small       # LLM-as-judge 评测打分

# ───────────────────────────────────────────────────────────
# 四、各层独立配置（仅当 *_LAYER=custom 时生效）
# ───────────────────────────────────────────────────────────
# 以下配置保持向后兼容；当某层设为 "custom" 时才会读取。
# 留空则自动 fallback 到 chat 的旧行为。
CHAT_BASE_URL=
CHAT_API_KEY=
CHAT_MODEL=
CORE_BASE_URL=
CORE_API_KEY=
CORE_MODEL=
PLANNER_BASE_URL=
PLANNER_API_KEY=
PLANNER_MODEL=
REWRITE_BASE_URL=
REWRITE_API_KEY=
REWRITE_MODEL=
MEMORY_BASE_URL=
MEMORY_API_KEY=
MEMORY_MODEL=
JUDGE_BASE_URL=
JUDGE_API_KEY=
JUDGE_MODEL=

# ───────────────────────────────────────────────────────────
# 五、特殊独立配置（不跟随大/小模型池）
# ───────────────────────────────────────────────────────────

# Vision 多模态（图片OCR、JD截图解析、简历图片解析）
# 推荐：qwen-vl-plus（通义千问多模态，国内最佳之一）
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_API_KEY=sk-your-key-here
VISION_MODEL=qwen-vl-plus

# Embedding 向量模型（默认复用大模型的 base_url/api_key）
# 推荐：text-embedding-v4（DashScope，中文效果优秀）
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-v4

# ───────────────────────────────────────────────────────────
# 六、外部工具配置
# ───────────────────────────────────────────────────────────

# Tavily 搜索（外部检索增强，国内可直接访问）
# 注册: https://tavily.com/  免费额度: 1000次/月
TAVILY_SEARCH_ENABLED=false
TAVILY_API_KEY=tvly-your-key-here
TAVILY_MAX_RESULTS=5
