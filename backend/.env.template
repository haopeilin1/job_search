# ═══════════════════════════════════════════════════════════
# 求职雷达 Agent — .env 配置模板
# 使用方法：复制本文件为 .env，填入你的 API Key 即可
#   cp .env.template .env
# ═══════════════════════════════════════════════════════════


# ==========================================================
# 一、大模型池（LARGE_*）— 强推理任务
# ==========================================================
# 【使用场景】
#   · 最终对话回复（流式输出给用户）
#   · 意图识别 L3 兜底仲裁（当 L1/L2 置信度不足时）
#   · 若 CORE/PLANNER 等层设为 "large"，则复用此池
#
# 【方案 A：通义千问 DashScope】推荐国内用户
#   注册: https://dashscope.aliyun.com/  免费额度充足
#   模型推荐: qwen-plus（32K上下文，推理强）
LARGE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LARGE_API_KEY=sk-你的密钥
LARGE_MODEL=qwen-plus

# 【方案 B：DeepSeek】性价比极高
#   注册: https://platform.deepseek.com/
#   模型推荐: deepseek-chat（即 deepseek-v3）
# LARGE_BASE_URL=https://api.deepseek.com/v1
# LARGE_API_KEY=sk-你的密钥
# LARGE_MODEL=deepseek-chat

# 【方案 C：OpenAI / Azure】国际用户
# LARGE_BASE_URL=https://api.openai.com/v1
# LARGE_API_KEY=sk-你的密钥
# LARGE_MODEL=gpt-4o

# 【方案 D：本地 Ollama / vLLM】零成本，需本地下载模型
#   先安装 Ollama: https://ollama.com
#   拉取模型: ollama pull qwen2.5:14b
# LARGE_BASE_URL=http://localhost:11434/v1
# LARGE_API_KEY=          # 本地模型留空
# LARGE_MODEL=qwen2.5:14b


# ==========================================================
# 二、小模型池（SMALL_*）— 轻量快速任务
# ==========================================================
# 【使用场景】
#   · query 改写（指代消解、口语降噪）
#   · 意图识别 L2 审核
#   · 记忆压缩、话题切换
#   · LLM-as-judge 评测打分（若 JUDGE_LAYER=small）
#   · 若 REWRITE/MEMORY/JUDGE 等层设为 "small"，则复用此池
#
# 【方案 A：通义千问 DashScope】
#   模型推荐: qwen-turbo（极速版，极便宜）
SMALL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SMALL_API_KEY=sk-你的密钥
SMALL_MODEL=qwen-turbo

# 【方案 B：DeepSeek】
# SMALL_BASE_URL=https://api.deepseek.com/v1
# SMALL_API_KEY=sk-你的密钥
# SMALL_MODEL=deepseek-chat

# 【方案 C：本地 Ollama】
#   拉取模型: ollama pull qwen2.5:7b
# SMALL_BASE_URL=http://localhost:11434/v1
# SMALL_API_KEY=
# SMALL_MODEL=qwen2.5:7b


# ==========================================================
# 三、系统层级 → 模型池映射
# ==========================================================
# 值填 large | small | custom
#   large  → 复用【大模型池】（上方 LARGE_*）
#   small  → 复用【小模型池】（上方 SMALL_*）
#   custom → 使用下方【各层独立配置】（*_BASE_URL / *_API_KEY / *_MODEL）

CHAT_LAYER=large        # 最终回复生成、意图识别 L3 兜底仲裁
CORE_LAYER=large        # 匹配分析(match_analyze)、面试题生成(interview_gen)、属性验证、QA合成、全局排序
PLANNER_LAYER=large     # 任务规划(TaskPlanner.create_graph)、检索决策、意图兜底仲裁
REWRITE_LAYER=small     # query改写、指代消解、口语降噪
MEMORY_LAYER=small      # 记忆压缩、话题切换、意图识别 L2 审核
JUDGE_LAYER=custom      # LLM-as-judge 评测打分（★ 强烈建议单独配置）


# ==========================================================
# 四、各层独立配置（仅当 *_LAYER=custom 时生效）
# ==========================================================
# 一般不需要修改，保持留空即可。如需某层使用独立模型，填下方对应配置。

CHAT_BASE_URL=
CHAT_API_KEY=
CHAT_MODEL=

CORE_BASE_URL=
CORE_API_KEY=
CORE_MODEL=

PLANNER_BASE_URL=
PLANNER_API_KEY=
PLANNER_MODEL=

REWRITE_BASE_URL=
REWRITE_API_KEY=
REWRITE_MODEL=

MEMORY_BASE_URL=
MEMORY_API_KEY=
MEMORY_MODEL=

# ★ JUDGE 独立配置（强烈推荐）
# 【使用场景】LLM-as-judge 评测打分，调用位置：
#   · eval/run_eval_v3.py — llm_judge() / process_quality_judge() / _run_v2_judge()
#   · 直接读取 settings.JUDGE_BASE_URL / JUDGE_API_KEY / JUDGE_MODEL
# 【推荐配置】小模型即可，如 qwen-turbo / glm-4-flash / 本地 qwen2.5:7b
# 【注意】即使 JUDGE_LAYER=small/large，run_eval_v3.py 中仍会优先读取 JUDGE_* 独立变量做 fallback
JUDGE_BASE_URL=
JUDGE_API_KEY=
JUDGE_MODEL=


# ==========================================================
# 五、特殊独立配置（不跟随大/小模型池）
# ==========================================================

# ── Vision 多模态（图片OCR、JD截图解析、简历图片解析）──
# 【使用场景】PDF 图片兜底解析、简历图片 OCR
# 推荐: qwen-vl-plus（通义千问多模态，国内最佳之一）
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_API_KEY=sk-你的密钥
VISION_MODEL=qwen-vl-plus

# ── Embedding 向量模型（用于知识库向量检索）──
# 【使用场景】简历/JD 文本向量化，ChromaDB 存储与检索
# 推荐: text-embedding-v4（DashScope，中文效果优秀）
#       text-embedding-3-small（OpenAI，便宜稳定）
# 【注意】若 EMBEDDING_BASE_URL/API_KEY 留空，则自动复用大模型池配置
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=sk-你的密钥
EMBEDDING_MODEL=text-embedding-v4


# ==========================================================
# 六、外部搜索工具（可选）
# ==========================================================

# ── Tavily 搜索（外部检索增强，国内可直接访问）──
# 注册: https://tavily.com/  免费额度: 1000次/月
# 当知识库召回不足时，系统会自动触发外部搜索补充
TAVILY_SEARCH_ENABLED=false
TAVILY_API_KEY=tvly-你的密钥
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5


# ==========================================================
# 七、Agent 路线配置
# ==========================================================
# "llm"  = LLM Agent 路线（Query改写 → 意图识别 → Plan → ReAct → 聚合回复）
# "rule" = 规则路线（固定 IntentRouter → Plan → 执行 → LLM 回复）
# "auto" = 读取 DEFAULT_AGENT_MODE 决定
AGENT_MODE=llm
DEFAULT_AGENT_MODE=llm


# ==========================================================
# 八、检索与重排序配置（一般保持默认）
# ==========================================================

# 混合召回配置
RETRIEVAL_TOP_K=20
RETRIEVAL_VEC_TOP_K=20
RETRIEVAL_BM25_TOP_K=20
RETRIEVAL_VEC_WEIGHT=0.70
RETRIEVAL_BM25_WEIGHT=0.30

# CrossEncoder 重排序
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_TOP_K=10
RERANKER_BATCH_SIZE=8
RERANKER_MAX_LENGTH=512

# 各意图默认检索数量
EXPLORE_TOP_K=15
MATCH_TOP_K=5
VERIFY_TOP_K=10
ASSESS_TOP_K=5

# 证据缓存（多轮复用）
EVIDENCE_CACHE_ENABLED=true
EVIDENCE_CACHE_MAX_SIZE=5
EVIDENCE_CACHE_RELEVANCE_THRESHOLD=0.6
